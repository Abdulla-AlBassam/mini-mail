[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn] 
C = GB
ST = Tyne and Wear
L = Newcastle
O = Northumbria University
OU = Dissertation Project
CN = mail.local

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = mail.local
DNS.2 = localhost
DNS.3 = mailserver.docker.local
IP.1 = 127.0.0.1
